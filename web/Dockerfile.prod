# Build stage
FROM node:22-alpine AS build
RUN apk update && apk add --no-cache build-base gcc autoconf automake zlib > /dev/null 2>&1

WORKDIR /opt/
COPY package.json package-lock.json ./
COPY cms/package.json cms/
COPY web/package.json web/
RUN npm config set fetch-retry-maxtimeout 600000 -g && npm ci
ENV PATH=/opt/node_modules/.bin:$PATH

WORKDIR /opt/app
COPY . .

# Baked into the client bundle at build time; override for your public Strapi URL in production.
ARG VITE_STRAPI_URL=http://strapi:1337
ENV VITE_STRAPI_URL=${VITE_STRAPI_URL}
ENV NODE_ENV=production

WORKDIR /opt/app/web
RUN npm run build

# Production stage — Nitro bundles server deps into .output
FROM node:22-alpine AS runner
RUN apk add --no-cache wget
ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3030

RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 webapp

WORKDIR /opt/app/web
COPY --from=build --chown=webapp:nodejs /opt/app/web/.output ./.output

USER webapp
EXPOSE 3030
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:3030/ || exit 1
CMD ["node", ".output/server/index.mjs"]
